# ID de la carpeta de Google Drive donde se encuentran los archivos exportados
# por el sistema de gestión. Puede ser encontrado en la URL de la carpeta,
# después de "folders/".
GDRIVE_FOLDER_ID="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Correo electrónico de la cuenta de servicio de Google Cloud con acceso a la
# carpeta de Google Drive especificada anteriormente.
GDRIVE_TARGET_SERVICE_ACCOUNT="robot@project-id.iam.gserviceaccount.com"

# Clave de la API de Tienda de Puntos. Pedir a un asesor de la plataforma.
TDP_API_KEY="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# URL del proyecto de Supabase. Puede ser encontrado en el panel de control de
# Supabase.
SUPABASE_URL="https://xxxxxxxxxxxxxxxxxxxx.supabase.co"

# Clave secreta de Supabase. Puede ser encontrado en el panel de control de
# Supabase, en la sección de "Project Settings > API Keys". No confundir con la
# service role key, que es legacy, o con la publishable/anon key.
SUPABASE_SECRET_KEY="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Fecha de inicio para la importación de ventas. Solo se procesarán los archivos
# exportados por el sistema de gestión que tengan una fecha igual o posterior.
START_DATE="20260101"

# Números de cliente a ignorar, separados por comas. Esto es útil para excluir
# clientes internos que no deberían acumular puntos, como sucursales, incluso si
# tienen un mail registrado en el sistema de gestión.
IGNORED_CLIENT_NUMBERS="1, 2, 9999"
